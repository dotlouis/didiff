    "cmdk": "^1.1.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.23.0",
    "prettier": "^3.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.12.1",
    "serve": "^14.2.6",
    "shadcn": "^4.13.0",
