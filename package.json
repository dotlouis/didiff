{
  "name": "didiff",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Local paste-to-paste diff checker PWA powered by @pierre/diffs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port ${PORT:-4173}",
    "start": "serve dist -s -l tcp://0.0.0.0:${PORT:-8080}",
    "lint": "oxlint"
  },
  "dependencies": {
